font-family="Hack Nerd Font Mono"

# theme = Neon
# theme = Sugarplum
# theme = tokyonight_night
theme = coolnight

cursor-style = underline 
cursor-style-blink = true 
shell-integration-features = no-cursor
mouse-hide-while-typing = true

background-opacity=0.85

keybind = ctrl+s>s=new_split:down
keybind = ctrl+s>w=new_split:up
keybind = ctrl+s>d=new_split:right
keybind = ctrl+s>a=new_split:left


keybind = ctrl+s>down=goto_split:down
keybind = ctrl+s>up=goto_split:up
keybind = ctrl+s>right=goto_split:right
keybind = ctrl+s>left=goto_split:left

keybind = ctrl+s>j=goto_split:down
keybind = ctrl+s>k=goto_split:up
keybind = ctrl+s>l=goto_split:right
keybind = ctrl+s>h=goto_split:left

keybind = ctrl+s>x=close_surface

keybind = ctrl+backspace=text:\x1b\x7f
