// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "dock": "right",
  },
  "terminal": {
    "dock": "bottom",
  },
  "outline_panel": {
    "dock": "right",
  },
  "icon_theme": "Catppuccin Mocha",
  "hide_mouse": "on_typing_and_movement",
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },

  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show": true,
  },

  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },

  "project_panel": { "dock": "right" },

  "diagnostics": { "inline": { "enabled": true } },

  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "format_on_save": "on",

  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
    },
    "model_parameters": [],
  },

  "lsp": {
    "eslint": {
      "settings": {
        "run": "onSave",
        "autoFixOnSave": true,
      },
    },
    "phpactor": {
      "settings": {
        "phpactor.enable": true,
        "language_server_phpstan.enabled": false,
        "language_server_psalm.enabled": false,
        "language_server_worse_reflection.inlay_hints.enable": false,
        "worse_reflection.enable_cache": true,
        "language_server.diagnostics_on_update": false,
        "language_server.diagnostics_on_save": false,
      },
    },
    "postgres-language-server": {
      "settings": {
        "lint": {
          "rules": {
            "safety/banDropTable": "off",
          },
        },
      },
    },
  },

  "languages": {
    "Nginx": {
      "hard_tabs": true,
      "enable_language_server": false,
    },
    "PHP": {
      "language_servers": ["phpactor", "..."],
      "formatter": "language_server",
      "format_on_save": "on",
      "tab_size": 4,
    },
    "Vue.js": {
      "language_servers": ["volar", "eslint", "..."],
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["prettier", "--write", "--parser", "vue"],
        },
      },
      "format_on_save": "on",
      "tab_size": 2,
    },
    "JavaScript": {
      "language_servers": ["typescript-language-server", "eslint", "..."],
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["prettier", "--write", "--parser", "babel"],
        },
      },
      "format_on_save": "on",
      "tab_size": 2,
    },
    "TypeScript": {
      "language_servers": ["typescript-language-server", "eslint", "..."],
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["prettier", "--write", "--parser", "typescript"],
        },
      },
      "format_on_save": "on",
      "tab_size": 2,
    },
    "CSS": {
      "language_servers": ["tailwindcss-language-server", "..."],
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["prettier", "--write", "--parser", "css"],
        },
      },
      "format_on_save": "on",
      "tab_size": 2,
    },
    "C": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["-style={BasedOnStyle: LLVM, ColumnLimit: 0}"],
        },
      },
    },
  },
}
